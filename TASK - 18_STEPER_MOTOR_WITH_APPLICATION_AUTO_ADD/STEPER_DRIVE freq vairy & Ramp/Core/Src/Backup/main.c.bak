void Debug_Print(char *msg)
{
    HAL_UART_Transmit(&huart2,
                      (uint8_t*)msg,
                      strlen(msg),
                      100);
}

void TIM2_Calculate(uint32_t freq, uint32_t *psc, uint32_t *arr)
{
    uint32_t timerClock = 72000000;

    *psc = 0;

    while(1)
    {
        *arr = (timerClock / ((*psc + 1) * freq)) - 1;

        if(*arr <= 65535)
        {
            break;
        }

        (*psc)++;

        if(*psc > 65535)
        {
            *psc = 0;
            *arr = 0;
            break;
        }
    }
}

void TIM2_Update(void)
{
    uint32_t psc;
    uint32_t arr;
    uint32_t ccr;

    TIM2_Calculate(pwmFrequency, &psc, &arr);

    __HAL_TIM_SET_PRESCALER(&htim2, psc);
    __HAL_TIM_SET_AUTORELOAD(&htim2, arr);

    ccr = ((arr + 1) * pwmDuty) / 100;

    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, ccr);

    __HAL_TIM_SET_COUNTER(&htim2, 0);

    htim2.Instance->EGR = TIM_EGR_UG;
}

void Motor_SetFrequency(uint32_t freq)
{
    if(freq == 0)
    {
        Debug_Print("ERR: FREQ\r\n");
        return;
    }

    pwmFrequency = freq;

    TIM2_Update();

    Debug_Print("OK: FREQ SET\r\n");
}

void Motor_SetDuty(uint8_t duty)
{
    if(duty > 100)
    {
        Debug_Print("ERR: DUTY\r\n");
        return;
    }

    pwmDuty = duty;

    TIM2_Update();

    Debug_Print("OK: DUTY SET\r\n");
}

void Motor_Start(void)
{
    HAL_GPIO_WritePin(PWM_EN_GPIO_Port,
                      PWM_EN_Pin,
                      GPIO_PIN_RESET);

    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);

    motorEnable = 1;

    Debug_Print("MOTOR ON\r\n");
}

void Motor_Stop(void)
{
    HAL_TIM_PWM_Stop(&htim2, TIM_CHANNEL_1);

    HAL_GPIO_WritePin(PWM_EN_GPIO_Port,
                      PWM_EN_Pin,
                      GPIO_PIN_SET);

    motorEnable = 0;

    Debug_Print("MOTOR OFF\r\n");
}

void Motor_Forward(void)
{
    HAL_GPIO_WritePin(PWM_DIR_GPIO_Port,
                      PWM_DIR_Pin,
                      GPIO_PIN_SET);

    Debug_Print("DIR FWD\r\n");
}

void Motor_Reverse(void)
{
    HAL_GPIO_WritePin(PWM_DIR_GPIO_Port,
                      PWM_DIR_Pin,
                      GPIO_PIN_RESET);

    Debug_Print("DIR REV\r\n");
}

uint8_t String_Compare(char *str1, char *str2)
{
    while(*str1 && *str2)
    {
        if(*str1 != *str2)
            return 0;

        str1++;
        str2++;
    }

    return (*str1 == *str2);
}

uint8_t String_To_Int(char *str, uint32_t *value)
{
    *value = 0;

    if(*str == '\0')
        return 0;

    while(*str)
    {
        if(*str < '0' || *str > '9')
            return 0;

        *value = (*value * 10) + (*str - '0');

        str++;
    }

    return 1;
}

Parser_Status_t Parse_Command(char *rx)
{
    char command[10] = {0};
    char valueStr[10] = {0};

    uint8_t i = 0;
    uint8_t j = 0;
    uint32_t value;


    /* Check start */
    if(rx[0] != '(')
        return PARSER_ERROR;


    /* Extract command */
    i = 1;

    while(rx[i] &&
          rx[i] != '$' &&
          rx[i] != '&' &&
          j < sizeof(command)-1)
    {
        command[j++] = rx[i++];
    }

    command[j] = '\0';


    /* Check separator */
    if(rx[i] != '$' && rx[i] != '&')
        return PARSER_ERROR;


    i++;
    j = 0;


    /* Extract value */
    while(rx[i] &&
          rx[i] != ')' &&
          j < sizeof(valueStr)-1)
    {
        valueStr[j++] = rx[i++];
    }

    valueStr[j] = '\0';


    /* Check end */
    if(rx[i] != ')')
        return PARSER_ERROR;


    /* Convert value */
    if(String_To_Int(valueStr, &value) == 0)
        return PARSER_INVALID_VALUE;


    /* Execute command */

    if(String_Compare(command, "freq"))
    {
        Motor_SetFrequency(value);
    }

    else if(String_Compare(command, "duty"))
    {
        Motor_SetDuty(value);
    }

    else if(String_Compare(command, "forwd"))
    {
        if(value)
        {
            Motor_Forward();
            Motor_Start();
        }
        else
        {
            Motor_Stop();
        }
    }

    else if(String_Compare(command, "back"))
    {
        if(value)
        {
            Motor_Reverse();
            Motor_Start();
        }
        else
        {
            Motor_Stop();
        }
    }

    else
    {
        return PARSER_UNKNOWN_CMD;
    }


    return PARSER_OK;
}



