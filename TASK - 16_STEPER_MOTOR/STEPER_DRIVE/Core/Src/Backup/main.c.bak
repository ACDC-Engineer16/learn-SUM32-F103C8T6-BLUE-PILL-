void Debug_Print(char *msg)
{
    HAL_UART_Transmit(&huart2,
                      (uint8_t*)msg,
                      strlen(msg),
                      100);
}

void Set_PWM_Frequency(uint32_t freq)
{
    if(freq == 0)
        return;

    if(freq > 50000)
        freq = 50000;

    frequency = freq;

    uint32_t arr = (1000000/freq)-1;

    __HAL_TIM_SET_AUTORELOAD(&htim2, arr);

    __HAL_TIM_SET_COMPARE(
        &htim2,
        TIM_CHANNEL_1,
        (arr+1)*duty/100
    );
}
void Set_PWM_Duty(uint8_t d)
{
    if(d > 100)
        d = 100;

    duty = d;

    uint32_t arr =
        __HAL_TIM_GET_AUTORELOAD(&htim2);

    __HAL_TIM_SET_COMPARE(
        &htim2,
        TIM_CHANNEL_1,
        ((arr+1)*duty)/100
    );
}
void Motor_Start(void)
{
    HAL_GPIO_WritePin(PWM_EN_GPIO_Port,
                      PWM_EN_Pin,
                      GPIO_PIN_RESET);   // Enable Driver

    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);

    motorEnable = 1;

    Debug_Print("Motor ON\r\n");
}
void Motor_Stop(void)
{
    HAL_TIM_PWM_Stop(&htim2, TIM_CHANNEL_1);

    HAL_GPIO_WritePin(PWM_EN_GPIO_Port,
                      PWM_EN_Pin,
                      GPIO_PIN_SET);     // Disable Driver

    motorEnable = 0;

    Debug_Print("Motor OFF\r\n");
}

uint8_t String_Compare(char *s1, char *s2)
{
    while(*s1 && *s2)
    {
        if(*s1 != *s2)
        {
            return 0;
        }

        s1++;
        s2++;
    }

    return (*s1 == '\0' && *s2 == '\0');
}
uint32_t String_To_Int(char *str)
{
    uint32_t value = 0;

    while(*str >= '0' && *str <= '9')
    {
        value = value * 10;
        value = value + (*str - '0');
        str++;
    }

    return value;
}


void Parse_Command(char *rx)
{
    char command[10] = {0};
    char number[10]  = {0};

    uint8_t i = 0;
    uint8_t j = 0;
    uint32_t value = 0;

    // Check start bracket
    if(rx[0] != '(')
    {
        Debug_Print("ERR: Missing (\r\n");
        return;
    }

    i = 1; // Skip '('


    // Get command
    while(rx[i] &&
          rx[i] != '$' &&
          rx[i] != '&' &&
          j < sizeof(command)-1)
    {
        command[j++] = rx[i++];
    }

    command[j] = '\0';


    // Check separator
    if(rx[i] != '$' && rx[i] != '&')
    {
        Debug_Print("ERR: Separator\r\n");
        return;
    }

    i++; // Skip $ or &


    // Get value
    j = 0;

    while(rx[i] &&
          rx[i] != ')' &&
          j < sizeof(number)-1)
    {
        number[j++] = rx[i++];
    }

    number[j] = '\0';


    // Check ending bracket
    if(rx[i] != ')')
    {
        Debug_Print("ERR: Missing )\r\n");
        return;
    }


    // Convert ASCII to number
    value = String_To_Int(number);


    // ==========================
    // Command Processing
    // ==========================

    if(String_Compare(command, "freq"))
    {
        if(value == 0 || value > 50000)
        {
            Debug_Print("ERR: Frequency\r\n");
            return;
        }

        Set_PWM_Frequency(value);
        Debug_Print("OK: Frequency Set\r\n");
    }


    else if(String_Compare(command, "duty"))
    {
        if(value > 100)
        {
            Debug_Print("ERR: Duty\r\n");
            return;
        }

        Set_PWM_Duty(value);
        Debug_Print("OK: Duty Set\r\n");
    }


    else if(String_Compare(command, "forwd"))
    {
        if(value == 1)
        {
            HAL_GPIO_WritePin(PWM_DIR_GPIO_Port,
                  PWM_DIR_Pin,
                  GPIO_PIN_SET);

						Motor_Start();
            Debug_Print("OK: Forward Start\r\n");
        }
        else if(value == 0)
        {
            Motor_Stop();

            Debug_Print("OK: Motor Stop\r\n");
        }
        else
        {
            Debug_Print("ERR: Forward Value\r\n");
        }
    }


    else if(String_Compare(command, "back"))
    {
        if(value == 1)
        {
            HAL_GPIO_WritePin(PWM_DIR_GPIO_Port,
                  PWM_DIR_Pin,
                  GPIO_PIN_RESET);

						Motor_Start();

            Debug_Print("OK: Reverse Start\r\n");
        }
        else if(value == 0)
        {
            Motor_Stop();

            Debug_Print("OK: Motor Stop\r\n");
        }
        else
        {
            Debug_Print("ERR: Back Value\r\n");
        }
    }


    else if(String_Compare(command, "stop"))
    {
        Motor_Stop();

        Debug_Print("OK: Stop\r\n");
    }


    else
    {
        Debug_Print("ERR: Unknown CMD\r\n");
    }
}

